    {
      "parameters": {
        "jsCode": "const events = $input.all();\nconst firstItem = events[0].json;\n\nconst windowStart = new Date(firstItem.window?.start || $('if_payload_valid').first().json.window.start).getTime();\nconst windowEnd = new Date(firstItem.window?.end || $('if_payload_valid').first().json.window.end).getTime();\nconst durationMs = (firstItem.duration_minutes || $('if_payload_valid').first().json.duration_minutes) * 60 * 1000;\n\n// Construir bloques ocupados desde los eventos reales del calendario\nconst busyBlocks = events\n  .filter(item => item.json.start?.dateTime && item.json.end?.dateTime)\n  .map(item => ({\n    start: new Date(item.json.start.dateTime).getTime(),\n    end: new Date(item.json.end.dateTime).getTime()\n  }))\n  .sort((a, b) => a.start - b.start);\n\n// Fusionar bloques solapados\nconst merged = [];\nfor (const block of busyBlocks) {\n  if (merged.length === 0 || block.start > merged[merged.length - 1].end) {\n    merged.push({ ...block });\n  } else {\n    merged[merged.length - 1].end = Math.max(merged[merged.length - 1].end, block.end);\n  }\n}\n\n// Calcular gaps libres y generar slots\nconst slots = [];\nlet cursor = windowStart;\n\nfor (const block of merged) {\n  if (block.start > cursor && (block.start - cursor) >= durationMs) {\n    slots.push({\n      start: new Date(cursor).toISOString(),\n      end: new Date(cursor + durationMs).toISOString()\n    });\n  }\n  cursor = Math.max(cursor, block.end);\n}\n\n// Gap final\nif ((windowEnd - cursor) >= durationMs) {\n  slots.push({\n    start: new Date(cursor).toISOString(),\n    end: new Date(cursor + durationMs).toISOString()\n  });\n}\n\nconst validData = $('if_payload_valid').first().json;\n\nreturn [{\n  json: {\n    slots: slots.slice(0, 5),\n    participants: validData.participants,\n    window: validData.window,\n    duration_minutes: validData.duration_minutes\n  }\n}];"
      },
