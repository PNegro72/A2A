      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\nconst errors = [];\n\nif (!body.participants || !Array.isArray(body.participants) || body.participants.length < 2) {\n  errors.push(\"'participants' must be an array with at least 2 emails\");\n}\n\nif (!body.window || !body.window.start || !body.window.end) {\n  errors.push(\"'window.start' y 'window.end' are required fields\");\n}\n\nif (!body.duration_minutes || typeof body.duration_minutes !== 'number' || body.duration_minutes <= 0) {\n  errors.push(\"'duration_minutes' must be a positive number\");\n}\n\nif (errors.length > 0) {\n  return [{\n    json: {\n      valid: false,\n      errors: errors\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    valid: true,\n    participants: body.participants,\n    window: body.window,\n    duration_minutes: body.duration_minutes\n  }\n}];"
      },
