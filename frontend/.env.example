# =============================================================
# SAPE PWA — Variables de entorno
# Copiar a .env.local y ajustar según el entorno.
# En Angular estas variables se configuran en src/environments/
# =============================================================

# URL base del Orchestrator (sin barra final)
ORCHESTRATOR_BASE_URL=http://localhost:8000

# Endpoints relativos a la base
ORCHESTRATOR_CHAT_ENDPOINT=/chat
ORCHESTRATOR_STREAM_ENDPOINT=/chat/stream

# Identidad visible del agente en la UI
AGENT_NAME=SAPE
AGENT_AVATAR_INITIALS=S

# Modo de transporte: 'sse' (Server-Sent Events) o 'polling'
# SSE es preferido; usar polling solo si el servidor no soporta SSE
TRANSPORT_MODE=sse

# Intervalo de polling en ms (solo aplica si TRANSPORT_MODE=polling)
POLLING_INTERVAL_MS=1000

# Timeout máximo de request en ms (2 minutos por defecto)
REQUEST_TIMEOUT_MS=120000
